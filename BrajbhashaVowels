# Step 6: Function to generate random points within convex hull using rejection sampling (simpler and more reliable than triangulation)
generate_random_point_in_convex_hull <- function(hull_points, n = 1, max_attempts = 100000) {
  # hull_points should be a dataframe with columns F2_norm, F1_norm (closed polygon)
  # Remove the last repeated point for the polygon definition
  hull_unique <- hull_points[1:(nrow(hull_points) - 1), ]
  
  # Create a SpatialPolygons object for point-in-polygon testing
  poly_matrix <- as.matrix(hull_unique[, c("F2_norm", "F1_norm")])
  poly <- Polygon(poly_matrix)
  polys <- Polygons(list(poly), 1)
  sp_poly <- SpatialPolygons(list(polys))
  
  # Get bounding box for efficient sampling
  x_range <- range(hull_unique$F2_norm)
  y_range <- range(hull_unique$F1_norm)
  
  points <- list()
  attempts <- 0
  
  while(length(points) < n && attempts < max_attempts) {
    # Generate random point in bounding box
    test_point <- cbind(runif(1, x_range[1], x_range[2]),
                        runif(1, y_range[1], y_range[2]))
    
    # Check if point is inside convex hull
    sp_point <- SpatialPoints(test_point)
    inside <- !is.na(over(sp_point, sp_poly))
    
    if(inside) {
      points <- append(points, list(c(test_point[1,1], test_point[1,2])))
    }
    attempts <- attempts + 1
  }
  
  if(length(points) < n) {
    warning(paste("Only generated", length(points), "points out of", n, 
                  "after", max_attempts, "attempts"))
  }
  
  # Return as matrix with column names
  result <- do.call(rbind, points)
  colnames(result) <- c("F2_norm", "F1_norm")
  return(result)
}

