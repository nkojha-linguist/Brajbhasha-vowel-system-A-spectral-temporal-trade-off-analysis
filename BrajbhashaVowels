# Function to create a cylinder mesh
create_cylinder <- function(x_center, y_center, z_height, color, radius = 0.1, segments = 20) {
  
  # Generate angles around the circle
  angles <- seq(0, 2 * pi, length.out = segments + 1)
  
  # Bottom circle points (z = 0)
  x_bottom <- x_center + radius * cos(angles)
  y_bottom <- y_center + radius * sin(angles)
  z_bottom <- rep(0, length(angles))
  
  # Top circle points (z = z_height)
  x_top <- x_center + radius * cos(angles)
  y_top <- y_center + radius * sin(angles)
  z_top <- rep(z_height, length(angles))
  
  # Combine all vertices
  vertices <- data.frame(
    x = c(x_bottom, x_top),
    y = c(y_bottom, y_top),
    z = c(z_bottom, z_top)
  )
  
  n <- segments + 1
  
  # Create indices for triangles
  i <- c()
  j <- c()
  k <- c()
  
  for (s in 1:segments) {
    b1 <- s
    b2 <- s + 1
    t1 <- n + s
    t2 <- n + s + 1
    
    i <- c(i, b1, b1, t1)
    j <- c(j, b2, t1, t2)
    k <- c(k, b2, t2, t2)
  }
  
  # Add bottom cap
  center_bottom <- which.min(rowSums((vertices[,1:2] - c(x_center, y_center))^2))
  for (s in 1:segments) {
    b1 <- s
    b2 <- s + 1
    i <- c(i, center_bottom, b1, b2)
    j <- c(j, b1, b2, center_bottom)
    k <- c(k, b2, center_bottom, b1)
  }
  
  # Add top cap
  center_top <- which.min(rowSums((vertices[1:n,1:2] - c(x_center, y_center))^2)) + n
  for (s in 1:segments) {
    t1 <- n + s
    t2 <- n + s + 1
    i <- c(i, center_top, t1, t2)
    j <- c(j, t1, t2, center_top)
    k <- c(k, t2, center_top, t1)
  }
  
  return(list(
    type = "mesh3d",
    x = vertices$x,
    y = vertices$y,
    z = vertices$z,
    i = i - 1,
    j = j - 1,
    k = k - 1,
    facecolor = rep(color, length(i)),
    opacity = 0.85,
    hoverinfo = "none",
    showlegend = FALSE
  ))
}

