# ----- Function for Static Vowel Space Plot -----
plot_vowel_space <- function(df, x, y, title, xlabel, ylabel) {
  # Calculate centroids for each vowel AND gender
  centroids <- df %>%
    group_by(Vowel, Gender) %>%
    summarise(centroid_x = mean(get(x), na.rm = TRUE), 
              centroid_y = mean(get(y), na.rm = TRUE), .groups = 'drop')
  
  ggplot(df, aes_string(x = x, y = y, color = "Vowel")) +
    geom_point(alpha = 0.7, size = 2.5) +
    stat_ellipse(type = "t", level = 0.95, size = 0.8, alpha = 0.6) +
    geom_text(aes(label = Vowel), vjust = 1.6, size = 3.2, show.legend = FALSE) +
    geom_point(data = centroids, aes(x = centroid_x, y = centroid_y, fill = Vowel), 
               color = "black", shape = 21, size = 9, stroke = 0.5, show.legend = FALSE) +
    scale_fill_brewer(palette = "Paired") +
    geom_text(data = centroids, aes(x = centroid_x, y = centroid_y, label = Vowel), 
              color = "black", size = 6, fontface = "bold", show.legend = FALSE) +
    scale_x_reverse() +
    scale_y_reverse() +
    facet_grid(~Gender) +
    scale_color_brewer(palette = "Paired") +
    labs(title = title, x = xlabel, y = ylabel) +
    theme_minimal(base_size = 13) +
    theme(strip.placement = "outside", 
          strip.background = element_rect(fill = "gray90", color = "gray60"), 
          legend.position = "right")
}

