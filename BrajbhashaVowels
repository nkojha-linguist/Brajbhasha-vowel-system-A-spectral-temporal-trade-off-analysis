  # These represent hypothetical vowel category centroids
  random_vowels <- generate_random_point_in_convex_hull(hull_points_closed, n_vowels)
  
  # Calculate the average pairwise Euclidean distance among these 10 random centroids
  sim_dist_matrix <- dist(random_vowels)
  mean(as.numeric(sim_dist_matrix))
})

cat("Simulations complete.\n")

# Step 9: Histogram comparing observed vs. simulated
hist(sim_scores, breaks = 40, col = "lightblue",
     main = "Simulated Dispersion of 10 Vowel Categories vs Observed",
     xlab = "Average Pairwise Euclidean Distance",
     xlim = range(c(sim_scores, obs_disp)))
abline(v = obs_disp, col = "red", lwd = 3)
legend("topright", legend = paste("Observed =", round(obs_disp, 3)), 
       col = "red", lwd = 3)

# Step 10: p-value
p_val <- mean(sim_scores >= obs_disp)
cat("\nProportion of simulated systems (10 categories) more dispersed than observed:", round(p_val, 4), "\n")

# Additional summary statistics
cat("\n--- Summary Statistics ---")
cat("\nMean simulated dispersion:", round(mean(sim_scores), 4))
cat("\nSD simulated dispersion:", round(sd(sim_scores), 4))
cat("\nObserved dispersion percentile in null distribution:", 
    round(mean(sim_scores <= obs_disp) * 100, 4), "%")

# Create a density plot comparison
sim_df <- data.frame(dispersion = sim_scores)
ggplot(sim_df, aes(x = dispersion)) +
  geom_density(fill = "lightblue", alpha = 0.6) +
  geom_vline(xintercept = obs_disp, color = "red", size = 1.2) +
  labs(title = "Density Plot: Simulated vs Observed Dispersion",
       x = "Average Pairwise Euclidean Distance", y = "Density") +
  annotate("text", x = obs_disp + 0.05, y = 0.5, 
           label = paste("Observed =", round(obs_disp, 4)), 
           color = "red", hjust = 0) +
  theme_minimal()
